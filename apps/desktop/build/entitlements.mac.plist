<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
                       "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened Runtime exemptions required by Electron's V8 engine.
       allow-jit: V8 JIT-compiles JS into RWX pages.
       allow-unsigned-executable-memory: Electron mmaps non-MAP_JIT executable
       pages; required on every Electron app to date.

       NOT included (deliberately):
       - com.apple.security.cs.disable-library-validation: only needed when
         loading native modules signed by a different team. PwrAgnt has zero
         native modules at v1.0; add only if a future native dep forces it. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
