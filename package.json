{
  "name": "pwragnt",
  "version": "1.0.0-alpha.0",
  "private": true,
  "description": "Thread-centric coding agent desktop app",
  "author": "PwrDrvr LLC",
  "license": "UNLICENSED",
  "copyright": "Copyright © 2026 PwrDrvr LLC. All rights reserved.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter @pwragnt/desktop build",
    "codex:generate-app-server-protocol": "pnpm --filter @pwragnt/shared codex:generate-app-server-protocol",
    "dev": "pnpm --filter @pwragnt/desktop dev",
    "dev:no-messaging": "PWRAGNT_DISABLE_MESSAGING=1 pnpm --filter @pwragnt/desktop dev -- --disable-messaging",
    "dev:op": "node ./scripts/op-run.mjs dev",
    "lint": "pnpm typecheck && pnpm lint:boundaries",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs apps/desktop/src/main/messaging packages/messaging",
    "test:desktop-e2e": "pnpm --filter @pwragnt/desktop build && pnpm --filter @pwragnt/desktop test:e2e",
    "test:desktop-e2e:nice": "node ./scripts/nice-run.mjs pnpm test:desktop-e2e",
    "test": "vitest run --config vitest.workspace.ts",
    "test:nice": "node ./scripts/nice-run.mjs pnpm test",
    "test:watch": "vitest --config vitest.workspace.ts",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dependency-cruiser": "^17.3.10",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
