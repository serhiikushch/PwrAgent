{
  "name": "pwragent-workspace",
  "version": "1.0.0-alpha.0",
  "private": true,
  "description": "Thread-centric coding agent desktop app",
  "author": "PwrDrvr LLC",
  "license": "MIT",
  "copyright": "Copyright © 2026 PwrDrvr LLC.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter @pwragent/desktop build",
    "codex:generate-app-server-protocol": "pnpm --filter @pwragent/codex-app-server-protocol generate",
    "dev": "pnpm --filter @pwragent/desktop dev",
    "dev:dev": "pnpm --filter @pwragent/desktop dev:dev",
    "dev:no-messaging": "PWRAGENT_DISABLE_MESSAGING=1 pnpm --filter @pwragent/desktop dev -- --disable-messaging",
    "dev:op": "node ./scripts/op-run.mjs dev",
    "op:dev": "node ./scripts/op-run.mjs dev",
    "op:run": "node ./scripts/op-run.mjs run",
    "licenses:check": "node ./scripts/check-package-licenses.mjs && node ./scripts/generate-third-party-licenses.mjs --check",
    "licenses:generate": "node ./scripts/generate-third-party-licenses.mjs",
    "lint": "pnpm lint:sql && pnpm lint:colors && pnpm licenses:check && pnpm typecheck && pnpm lint:boundaries",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs packages/ apps/desktop/src/",
    "lint:colors": "node ./scripts/lint-renderer-colors.mjs",
    "lint:sql": "node ./scripts/lint-sql-templates.mjs",
    "release:check": "node ./scripts/check-desktop-release-metadata.mjs",
    "test:desktop-e2e": "pnpm --filter @pwragent/desktop test:e2e",
    "test:desktop-e2e:nice": "node ./scripts/nice-run.mjs pnpm test:desktop-e2e",
    "test": "vitest run --config vitest.workspace.ts",
    "test:nice": "node ./scripts/nice-run.mjs pnpm test",
    "test:watch": "vitest --config vitest.workspace.ts",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dependency-cruiser": "^17.3.10",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.16.0"
    }
  }
}
