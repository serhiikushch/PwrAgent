source "https://rubygems.org"

# Match GitHub Pages' renderer exactly — pins Jekyll, the minima theme,
# and the plugin set Pages enables. Whatever version is in this gem is
# what docs.pwragent.ai serves.
#
# Bump in lockstep with the version reported at
# https://pages.github.com/versions/
gem "github-pages", "~> 232", group: :jekyll_plugins

# webrick is no longer in Ruby's stdlib as of 3.0; Jekyll needs it for
# `serve`.
gem "webrick", "~> 1.8"
